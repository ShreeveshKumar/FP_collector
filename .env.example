# ── Scraper configuration ──────────────────────────────────────────────────────
# Copy this file to .env and fill in values. .env is git-ignored.

# Source A — HTML scraping endpoints
SRC_A_PRIMARY_URL=
SRC_A_DETAIL_URL=

# Source B — JSON API ({key} is substituted at runtime)
SRC_B_API_KEY=DEMO_KEY
SRC_B_BASE_URL=
SRC_B_SERIES_1_URL=
SRC_B_SERIES_2_URL=

# Source C — per-state fallback (HTML). Fills any state source A missed with
# real per-state data before falling back to the national average. Optional:
# the scraper ships with a working default, so this only overrides it.
SRC_C_FALLBACK_URL=

# HTTP headers sent with scraping requests
HTTP_USER_AGENT=
HTTP_ACCEPT=
HTTP_ACCEPT_LANGUAGE=
HTTP_REQUEST_ID=
HTTP_TRACE_ID=
HTTP_SESSION_TOKEN=
HTTP_CLIENT_ID=
HTTP_NONCE=

# ── MongoDB ─────────────────────────────────────────────────────────────────────
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_HOST=
MONGO_DB=
MONGO_PRICES_COLLECTION=
MONGO_META_COLLECTION=
# Optional: full connection string overrides the components above.
# MONGO_URI=
